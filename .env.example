

# =================== REQUIRED API KEYS ===================

# Groq API Keys (REQUIRED - FREE with high rate limits)
# Get from: https://console.groq.com/keys
# Used for: LLaMA 3.3 70B AI model (ultra-fast LLM inference)
# Provide a primary key and optional fallback keys. Do NOT commit real keys.
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_FALLBACK_1=optional_fallback_key_1
GROQ_API_KEY_FALLBACK_2=optional_fallback_key_2


# =================== SERVER CONFIGURATION ===================

# Host and Port (Railway will override PORT automatically)
HOST=0.0.0.0
PORT=8000

# CORS Origins (comma-separated for multiple origins)
# For local development:
ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# For production, add your deployment URLs:
# ALLOW_ORIGINS=https://your-app.railway.app,https://yourusername.github.io,https://your-custom-domain.com

# =================== OPTIONAL SETTINGS ===================

# Default Language (en or bn)
DEFAULT_LANGUAGE=en

# Enable Voice Features
ENABLE_VOICE=true

# Debug Mode (set to false in production)
DEBUG=false

# Optional startup warmup for embeddings / graph / whisper.
# Leave false for local development so the UI serves immediately.
ENABLE_PREWARM=false

# OpenAI keys (only required for some embedding/experimental features).
# Provide a primary and optional fallback key if you use OpenAI services.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_KEY_FALLBACK_1=optional_openai_fallback_key_1

# =================== DEPLOYMENT NOTES ===================

# Railway Deployment:
# 1. Create a new project on Railway (https://railway.app)
# 2. Connect your GitHub repository
# 3. Add environment variables in Railway dashboard:
#    - GROQ_API_KEY (required)
#    - NASA_API_KEY (recommended)
#    - WEATHER_UNDERGROUND_API_KEY (optional)
# 4. Railway will automatically set PORT
# 5. Deploy!

# Local Development:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your API keys in .env
# 3. Run: make dev (or python backend.py)
# 4. Visit: http://localhost:8000

# Persistence (optional):
# If you want chat/session/profile persistence across deploys, mount a
# persistent volume to the project's `chroma_db/` directory in Railway.
# On Railway, go to the project > Settings > Volumes and create a volume,
# then attach it to the service path `/app/chroma_db` (or the repo root path
# where Railway mounts your code) so the SQLite/Chroma data survives restarts.

# =================== IMPORTANT SECURITY NOTES ===================
# ⚠️ NEVER commit .env file to version control
# ⚠️ Keep your API keys secret
# ⚠️ Use different keys for development and production
# ✅ .env is already in .gitignore
# ✅ Only commit .env.example (this file)
